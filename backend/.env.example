# ==========================================
# BestDel Backend Environment Configuration
# ==========================================

# --- Server Configuration ---
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:5173

# --- Supabase Database & Cache ---
# Required for persistent cache and history
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# SUPABASE_JWT_SECRET=your_jwt_secret # Optional: For decoding auth tokens

# --- Redis Configuration (Optional) ---
# Used for rate limiting and transient caching
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# ==========================================
# AI Model Providers (Supports Multi-Key Fallback)
# ==========================================
# You can provide multiple keys for any provider by appending _1, _2, _3
# Example:
# GROQ_API_KEY=key_1
# GROQ_API_KEY_1=key_2
# GROQ_API_KEY_2=key_3

# --- Primary Generation Models ---
GROQ_API_KEY=your_groq_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key
NVIDIA_API_KEY=your_nvidia_api_key
CEREBRAS_API_KEY=your_cerebras_api_key

# --- Web Search Providers ---
# Tavily is highly recommended for best results
TAVILY_API_KEY=your_tavily_api_key
# TAVILY_API_KEY_1=your_backup_tavily_api_key
SERPER_API_KEY=your_serper_api_key
EXA_API_KEY=your_exa_api_key
BRAVE_API_KEY=your_brave_api_key

# --- Web Extractors ---
FIRECRAWL_API_KEY=your_firecrawl_api_key
JINA_API_KEY=your_jina_api_key
SCRAPERAPI_KEY=your_scraperapi_key
