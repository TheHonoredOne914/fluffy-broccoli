# ==========================================
# BestDel Backend Environment Configuration
# ==========================================

# --- Server Configuration ---
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:5173

# --- Supabase Database & Cache ---
# Required for persistent cache and history
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_JWT_SECRET=your_jwt_secret # Optional: For decoding auth tokens

# --- Redis Configuration (Optional) ---
# Used for rate limiting and transient caching
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# ==========================================
# AI Model Providers (Multi-Key Fallback)
# ==========================================

GROQ_API_KEY_1=your_groq_api_key_1
GROQ_API_KEY_2=your_groq_api_key_2
GROQ_API_KEY_3=your_groq_api_key_3

