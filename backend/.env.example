# ==========================================
# BestDel Backend Environment Configuration
# ==========================================
# WARNING: Do NOT put your actual API keys in this file.
# Copy this file to '.env' and put your real keys there.
# This file is pushed to GitHub.

# --- Server Configuration ---
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:5173

# --- Supabase Database & Cache ---
# Required for persistent cache and history
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_JWT_SECRET=your_jwt_secret # Optional: For decoding auth tokens

# --- Redis Configuration (Optional) ---
# Used for rate limiting and transient caching
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# ==========================================
# AI Model Providers (Multi-Key Fallback)
# ==========================================

